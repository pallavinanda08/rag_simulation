<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<title>RAG Simulator</title>

<style>

body{
font-family: Arial, Helvetica, sans-serif;
background:#0f172a;
color:white;
margin:0;
padding:30px;
}

h1{
text-align:center;
margin-bottom:30px;
}

.container{
max-width:1200px;
margin:auto;
}

.section{
background:#1e293b;
padding:20px;
margin-bottom:20px;
border-radius:10px;
}

textarea{
width:100%;
height:100px;
border-radius:6px;
padding:10px;
border:none;
margin-top:10px;
}

button{
background:#38bdf8;
border:none;
padding:10px 16px;
border-radius:6px;
margin-top:10px;
cursor:pointer;
font-weight:bold;
}

button:hover{
background:#0ea5e9;
}

.output{
background:#020617;
padding:12px;
margin-top:12px;
border-radius:6px;
min-height:40px;
}

.chunk{
background:#334155;
padding:8px;
margin:6px;
border-radius:6px;
display:inline-block;
}

.vector{
font-size:12px;
color:#93c5fd;
}

.answer{
background:#065f46;
padding:15px;
border-radius:8px;
margin-top:10px;
}

input{
width:100%;
padding:10px;
border-radius:6px;
border:none;
margin-top:10px;
}

</style>
</head>


<body>

<div class="container">

<h1>Retrieval Augmented Generation (RAG) Simulator</h1>


<div class="section">

<h2>1. Knowledge Base</h2>

<textarea id="docs">
WSO2 API Manager is used to publish, manage and secure APIs.

Vector databases store embeddings which allow semantic search.

Retrieval Augmented Generation improves LLM responses using external knowledge.

Chunking breaks large documents into smaller segments for retrieval.

Embeddings convert text into numerical vectors representing meaning.
</textarea>

<button onclick="createChunks()">Create Chunks</button>

<div id="chunks" class="output"></div>

</div>



<div class="section">

<h2>2. Generate Embeddings (Vectorization)</h2>

<button onclick="generateVectors()">Convert Chunks to Vectors</button>

<div id="vectors" class="output"></div>

</div>



<div class="section">

<h2>3. User Query</h2>

<input id="query" placeholder="Ask a question...">

<button onclick="runQuery()">Run RAG Pipeline</button>

</div>



<div class="section">

<h2>4. Retrieved Context</h2>

<div id="retrieved" class="output"></div>

</div>



<div class="section">

<h2>5. Augmented Generation</h2>

<div id="answer" class="answer"></div>

</div>


</div>


<script>

let chunks=[]
let vectors=[]


function createChunks(){

let text=document.getElementById("docs").value

chunks=text.split(".").map(c=>c.trim()).filter(c=>c.length>0)

let container=document.getElementById("chunks")

container.innerHTML=""

chunks.forEach((c,i)=>{

let div=document.createElement("div")

div.className="chunk"

div.innerText="Chunk "+(i+1)+": "+c

container.appendChild(div)

})

}



function textToVector(text){

let vector=[]

for(let i=0;i<5;i++){

vector.push(Math.random().toFixed(2))

}

return vector

}



function generateVectors(){

vectors=[]

let container=document.getElementById("vectors")

container.innerHTML=""

chunks.forEach(c=>{

let vec=textToVector(c)

vectors.push(vec)

let div=document.createElement("div")

div.innerHTML="<div class='vector'>["+vec.join(", ")+"]</div> "+c

container.appendChild(div)

})

}



function similarity(v1,v2){

let score=0

for(let i=0;i<v1.length;i++){

score+=v1[i]*v2[i]

}

return score

}



function runQuery(){

let query=document.getElementById("query").value

let queryVector=textToVector(query)

let scores=[]

for(let i=0;i<vectors.length;i++){

scores.push({

chunk:chunks[i],
score:similarity(queryVector,vectors[i])

})

}

scores.sort((a,b)=>b.score-a.score)

let top=scores.slice(0,2)

let retrieved=document.getElementById("retrieved")

retrieved.innerHTML=""

top.forEach(t=>{

let div=document.createElement("div")

div.className="chunk"

div.innerText=t.chunk

retrieved.appendChild(div)

})

generateAnswer(query,top)

}



function generateAnswer(query,context){

let combined=context.map(c=>c.chunk).join(". ")

let answer="Based on retrieved knowledge: "+combined+". Therefore the answer to '"+query+"' is derived from the above context."

document.getElementById("answer").innerText=answer

}



</script>

</body>
</html>
